{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {"const": "1.0"},
    "summary": {"type": "string"},
    "tasks": {
      "type": "array",
      "minItems": 2,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "local_id": {"type": "string"},
          "role": {"enum": ["coder", "tester", "reviewer"]},
          "goal": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["local_id", "role", "goal"]
      }
    }
  },
  "required": ["version", "summary", "tasks"]
}
